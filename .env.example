# OpsMind 环境变量 — 复制为 .env 后填写真实值
# 禁止提交含真实密钥的 .env 文件到版本控制
# 所有变量均可覆盖 config.yaml 对应字段

# 运行环境: development | production
APP_ENV=development

# Server
SERVER_PORT=8080
SERVER_MODE=debug

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=opsmind
DB_PASSWORD=opsmind123
DB_NAME=opsmind
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# NATS
NATS_URL=nats://localhost:4222
NATS_STREAM=opsmind

# docker-compose 端口映射（非应用配置，仅 docker 使用）
REDIS_PORT=6379
NATS_PORT=4222

# MinIO 对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=opsmind
MINIO_USE_SSL=false
# docker-compose 端口映射
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# AnythingLLM RAG 服务
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=

# vLLM 模型服务 (OpenAI-compatible)
VLLM_BASE_URL=http://localhost:8000
VLLM_API_KEY=
VLLM_MODEL=default

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_HOURS=168
