# OpsMind 环境变量 — 复制为 .env 后填写真实值
# 禁止提交含真实密钥的 .env 文件到版本控制

# 运行环境: development | production
APP_ENV=development

# Go API 服务
SERVER_PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=opsmind
DB_PASSWORD=opsmind123
DB_NAME=opsmind
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=

# NATS
NATS_URL=nats://localhost:4222
NATS_PORT=4222

# MinIO 对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=opsmind
MINIO_USE_SSL=false

# AnythingLLM RAG 服务
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=

# vLLM 模型服务 (OpenAI-compatible)
VLLM_BASE_URL=http://localhost:8000
VLLM_API_KEY=
VLLM_MODEL=default

# JWT
JWT_SECRET=change-me-in-production
